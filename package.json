        "license-checker": "^25.0.1",
        "msw": "^2.13.2",
        "prettier": "^3.6.2",
        "prettier-plugin-properties": "^0.3.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.46.2",
        "vite": "^7.1.12",
        "vite-plugin-checker": "^0.11.0",
